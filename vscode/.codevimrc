let mapleader = ","
let g:mapleader = ","

" fix behavior for deleting and cutting
nnoremap <leader>d "_d
xnoremap <leader>d "_d
xnoremap <leader>p "_dP
vnoremap P "_dp
vnoremap p "_dP

nnoremap d "_d
vnoremap d "_d
nnoremap D "_D
nnoremap x "_x

nnoremap <leader>d ""d
nnoremap <leader>D ""D
vnoremap <leader>d ""d
nnoremap <leader>dd ""dd

" retain selection after indenting
vnoremap < <gv
vnoremap > >gv

" allow cursor to go to empty space after last character
"set virtualedit+=onemore
set virtualedit=all
vnoremap t  !column -t<CR>
vnoremap t= !sed 's:[\ ]*=[\ ]*:=:' | column -s '=' -o ' = ' -t -l2 | sed -e 's:[=\ ]*$::' -e 's:  =  : = :' <CR>
vnoremap t: !sed 's/[\ ]*:[\ ]*/:/' | column -s ':' -o ': ' -t -l2 | sed -e 's/[:\ ]*$//' -e 's/  :  / : /' <CR>
vnoremap tf !sed -e 's:[\ ]*from[\ ]*:from:' -e 's:from:=:' | column -s '=' -o '=' -t -l2 | sed -e 's:[=\ ]*$::' -e 's:=: from :'<CR>


