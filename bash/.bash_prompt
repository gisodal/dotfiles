#!/bin/bash

# -----------------------------------------------------------------------------
# ANSI color codes
# -----------------------------------------------------------------------------

export STYLE_RESET="\033[0m"        #  reset
export STYLE_BRIGHT="\033[1m"       #  hicolor
export STYLE_UNDERLINE="\033[4m"    #  underline
export STYLE_INVERSE="\033[7m"      #  inverse     background  and  foreground
export COLOR_FG_BLACK="\033[30m"    #  foreground  black
export COLOR_FG_RED="\033[31m"      #  foreground  red
export COLOR_FG_GREEN="\033[32m"    #  foreground  green
export COLOR_FG_YELLOW="\033[33m"   #  foreground  yellow
export COLOR_FG_BLUE="\033[34m"     #  foreground  blue
export COLOR_FG_MAGENTA="\033[35m"  #  foreground  magenta
export COLOR_FG_CYAN="\033[36m"     #  foreground  cyan
export COLOR_FG_WHITE="\033[37m"    #  foreground  white
export COLOR_BG_BLACK="\033[40m"    #  background  black
export COLOR_BG_RED="\033[41m"      #  background  red
export COLOR_BG_GREEN="\033[42m"    #  background  green
export COLOR_BG_YELLOW="\033[43m"   #  background  yellow
export COLOR_BG_BLUE="\033[44m"     #  background  blue
export COLOR_BG_MAGENTA="\033[45m"  #  background  magenta
export COLOR_BG_CYAN="\033[46m"     #  background  cyan
export COLOR_BG_WHITE="\033[47m"    #  background  white

# -----------------------------------------------------------------------------
# 256 colors
# -----------------------------------------------------------------------------

function tmux-colors () {
    for i in {0..255}; do
        printf "\x1b[38;5;${i}mcolour${i}\x1b[0m\n"
    done | column
}
export -f tmux-colors

function create_color () { printf '%s%d%s' '\033[38;5;' "${1:=0}" 'm'; }
export -f create_color

export COLOR_FG_ORANGE=$(create_color 172)
export COLOR_FG_GREY=$(create_color 233)

# -----------------------------------------------------------------------------
# set prompt color
# -----------------------------------------------------------------------------

function __prompt_command(){
    RETURN_VALUE=$?

    # do not store duplicate commands in history
    history -a

    # reset terminal title (this is used in TMUX/VIM)
    printf '\x1b[0;\007'

    # set the prompt color based on the previous return value
    [ $RETURN_VALUE -eq 0 ] && export PROMPT_COLOR=$PROMPT_DEFAULT_COLOR || export PROMPT_COLOR=$COLOR_FG_RED
}

export PROMPT_COMMAND=__prompt_command
export PROMPT_DEFAULT_COLOR=$COLOR_FG_ORANGE
export PROMPT_COLOR=$COLOR_FG_ORANGE
export PROMPT_BOX_COLOR=$COLOR_FG_GREEN

# -----------------------------------------------------------------------------
# prompt appearance
# -----------------------------------------------------------------------------

PROMPT_PRIMARY=$(printf "\xe2\x97\x8f")
PROMPT_SECONDARY=$(printf "\xe2\x97\x8b")
BEGIN="\\\["
END="\\\]"

function unicode() {
    printf "\u${1}"
}

function wrap() {
    printf '%s%s%s' '\[' "$1" '\]'
}

function colorize() {
    printf '%s%s%s' "$(wrap $1)" "$2" "$(wrap $STYLE_RESET)"
}

function box() {
    #prompt_primary
    #printf '%s' "$(colorize "\$PROMPT_BOX_COLOR" X)"
    printf '%s' "$(colorize "\\\$PROMPT_BOX_COLOR" $(unicode $1))"
}

function prompt_primary() {
    printf '%s' "$(colorize '\$PROMPT_COLOR' $PROMPT_PRIMARY)"
}

function prompt_secondary() {
    printf '%s' "$(colorize '\$PROMPT_COLOR' $PROMPT_SECONDARY)"
}

function prompt_hostname() {
    printf '%s%s%s' "$(box 2500)" "" "" #$(box 005B)" "$(colorize $PROMPT_DEFAULT_COLOR x$HOSTNAME)" "$(box 005D)"
    #echo -en "$(box 2500)$(box 005B)$(colorize $PROMPT_DEFAULT_COLOR $HOSTNAME)$(box 005D)"
}

function prompt_context() {
    echo -en "$(box 2500)[$(pwd-context)]"

}

function prompt_element() {
    printf '%s%s%s' "$(box 2500)$(box 005B)" "$1" "$(box 005D)"

}
function prompt_git_context() {
    local context=$(git context)
    if [ ! -z "$context" ]; then
        local repository=${context%%:*}
        local branch=${context#*:}
        #repository="${COLOR_FG_BLUE}${repository}${STYLE_RESET}"
        #branch="${COLOR_FG_GREEN}${branch}${STYLE_RESET}"
        printf '%s%s' "$(prompt_element $repository)" "$(prompt_element $branch)"
    fi
}

function imp() {
    local RESULT=$(eval $@)
    echo -en "$RESULT"
}


function prompts() {
    printf "PS1: %s\n" "$PS1"
    printf "PS2: %s\n" "$PS2"
}
# \$(imp prompt_git_context)
# keep in mind color codes without surrounding [ and ] will screw up history lookup

#PS1="\n$(box 250c)$(prompt_hostname)\$(imp prompt_context)\n$(box 2514)$(prompt_primary) "
#PS1="\n\n \[$PROMPT_BOX_COLOR\]─\[\033[0m\]\[\\\$PROMPT_COLOR\]●\[\033[0m\] "
prompt_ps1() {
    printf '%s' "\n\n $(prompt_hostname)$(prompt_primary) "
}

PS1="\$COLOR_FG_GREEN\$(date)$STYLE_RESET "
PS2=" $(prompt_secondary) "

prompts
